#!/bin/zsh

set -eu

osascript <<'APPLESCRIPT'
on toggleNotificationCenter()
  tell application "System Events"
    key code 160 using control down
  end tell
end toggleNotificationCenter

on notificationCenterWindow()
  tell application "System Events"
    tell process "NotificationCenter"
      if exists window 1 then
        return window 1
      end if
    end tell
  end tell

  return missing value
end notificationCenterWindow

on run
  tell application "System Events"
    if UI elements enabled is false then
      error "System Events UI scripting is disabled."
    end if
  end tell

  toggleNotificationCenter()
  delay 0.2

  repeat with passIndex from 1 to 8
    set notificationWindow to notificationCenterWindow()
    if notificationWindow is missing value then
      exit repeat
    end if

    delay 0.05
  end repeat

  toggleNotificationCenter()
end run
APPLESCRIPT
